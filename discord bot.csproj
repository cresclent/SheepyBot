<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net10.0</TargetFramework>
		<RootNamespace>discord_bot</RootNamespace>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="NetCord" Version="1.0.0-beta.3" />
		<PackageReference Include="NetCord.Hosting" Version="1.0.0-beta.3" />
		<PackageReference Include="NetCord.Hosting.AspNetCore" Version="1.0.0-beta.3" />
		<PackageReference Include="NetCord.Hosting.Services" Version="1.0.0-beta.3" />
		<PackageReference Include="NetCord.Services" Version="1.0.0-beta.3" />
		<PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
		<PackageReference Include="System.Configuration.ConfigurationManager" Version="10.0.9" />
	</ItemGroup>

	<ItemGroup>
		<FrameworkReference Include="Microsoft.AspNetCore.App" />
	</ItemGroup>
	
	<ItemGroup>
		<None Update="appsettings.json">
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</None>
	</ItemGroup>

	<ItemGroup>
		<Folder Include="SmallDat\data\" />
	</ItemGroup>

</Project>