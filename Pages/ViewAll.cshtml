@page "{viewtype?}"
@model discord_bot.Pages.ViewAllModel
@{
}
<!DOCTYPE html>
<html>
<head>
    <title>Sheepy Bot - View All</title>
    <link rel="stylesheet" href="/css/site.css" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
</head>
<body>
    <div class="page-title">
        <h1>📊 View All Data</h1>
        <a href="/" class="back-link">← Back to Control Panel</a>
    </div>

    <div class="view-nav">
        <a href="/ViewAll/Votes" class="@(Model.ViewType == "Votes" ? "active" : "")">📊 Votes</a>
        <a href="/ViewAll/Startups" class="@(Model.ViewType == "Startups" ? "active" : "")">📢 Startup Channels</a>
        <a href="/ViewAll/Globals" class="@(Model.ViewType == "Globals" ? "active" : "")">🌍 Global Channels</a>
        <a href="/ViewAll/AllData" class="@(Model.ViewType == "AllData" ? "active" : "")">📊 All Data</a>
    </div>

    @if (Model.ViewType == string.Empty)
    {
        <div class="empty-state">
            <div class="icon">👆</div>
            <p>Select a view from the tabs above</p>
        </div>
    }
    else if (Model.ViewType == "Votes")
    {
        <h2>Votes</h2>
        @if (Model.Votes.Count > 0)
        {
            <table>
                <thead>
                    <tr>
                        <th>Vote ID</th>
                        <th>User ID</th>
                        <th>Vote Value</th>
                        <th>Timestamp</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var vote in Model.Votes)
                    {
                        <tr>
                            <td>@vote.VoteId</td>
                            <td>@vote.UserId</td>
                            <td>@vote.VoteValue</td>
                            <td>@vote.Timestamp</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <div class="icon">📭</div>
                <p>No votes found</p>
            </div>
        }
    }
    else if (Model.ViewType == "Startups")
    {
        <h2>Startup Channels</h2>
        @if (Model.StartupChannels.Count > 0)
        {
            <table>
                <thead>
                    <tr>
                        <th>Guild ID</th>
                        <th>Guild Name</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var channel in Model.StartupChannels)
                    {
                        <tr>
                            <td>@channel.ChannelId</td>
                            <td>@channel.ChannelName</td>
                            <td>Configured</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <div class="icon">📭</div>
                <p>No startup channels found</p>
            </div>
        }
    }
    else if (Model.ViewType == "Globals")
    {
        <h2>Global Channels</h2>
        @if (Model.GlobalChannels.Count > 0)
        {
            <table>
                <thead>
                    <tr>
                        <th>Guild ID</th>
                        <th>Guild Name</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var channel in Model.GlobalChannels)
                    {
                        <tr>
                            <td>@channel.ChannelId</td>
                            <td>@channel.ChannelName</td>
                            <td>Configured</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <div class="icon">📭</div>
                <p>No global channels found</p>
            </div>
            }
        }
        else if (Model.ViewType == "AllData")
    {
        <h2 class="section-title">📊 All Data Report</h2>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-label">Total Guilds</div>
                <div class="stat-value">@Model.AllDataReport.TotalGuilds</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Total Users</div>
                <div class="stat-value">@Model.AllDataReport.TotalUsers</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Total Commands</div>
                <div class="stat-value">@Model.AllDataReport.TotalCommands</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Command Users</div>
                <div class="stat-value">@Model.AllDataReport.TotalCommandUsers</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Suggestions</div>
                <div class="stat-value">@Model.AllDataReport.TotalSuggestions</div>
                <div class="stat-sub">
                    ⏳ @Model.AllDataReport.PendingSuggestions · ✅ @Model.AllDataReport.ApprovedSuggestions · ❌ @Model.AllDataReport.DeniedSuggestions
                </div>
            </div>
        </div>

        <h3 class="section-title">Vote Channels</h3>
        <div class="data-container">
            <pre>@Model.AllDataReport.VoteChannels</pre>
        </div>

        <h3 class="section-title">Startup Channels</h3>
        <div class="data-container">
            <pre>@Model.AllDataReport.StartupChannels</pre>
        </div>

        <h3 class="section-title">Global Channels</h3>
        <div class="data-container">
            <pre>@Model.AllDataReport.GlobalChannels</pre>
        </div>

        @if (Model.AllDataReport.TopUsersWithCommands.Count > 0)
        {
            <h3 class="section-title">Top Command Users</h3>
            <table>
                <thead>
                    <tr>
                        <th style="width: 60px;">Rank</th>
                        <th>User</th>
                        <th style="width: 120px;">Commands</th>
                        <th style="width: 40px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.AllDataReport.TopUsersWithCommands.Count; i++)
                    {
                        var user = Model.AllDataReport.TopUsersWithCommands[i];
                        var medal = i == 0 ? "🥇" : i == 1 ? "🥈" : i == 2 ? "🥉" : $"#{i + 1}";
                        var collapseId = $"userCollapse_{i}";
                        <tr class="user-row" onclick="toggleCollapse('@collapseId', this)">
                            <td>@medal</td>
                            <td>
                                <strong>@user.UserName</strong>
                                <span class="badge-count">@user.TotalCommands</span>
                            </td>
                            <td>@user.TotalCommands</td>
                            <td>
                                <span class="expand-icon" id="icon_@collapseId">▼</span>
                            </td>
                        </tr>
                        <tr class="command-details" id="@collapseId">
                            <td colspan="4">
                                <div style="padding: 8px 0;">
                                    <strong style="color: var(--text-muted); font-size: 0.8rem;">Command Usage:</strong>
                                    @if (user.CommandCounts.Count > 0)
                                    {
                                        <ul class="cmd-list">
                                            @foreach (var cmd in user.CommandCounts)
                                            {
                                                var cmdId = $"cmd_{collapseId}_{cmd.CommandName.Replace("/", "")}";
                                                <li>
                                                    <div class="cmd-header" onclick="toggleCmdTimestamps('@cmdId', event)">
                                                        <span class="command-span">
                                                            <span class="command-name">/@cmd.CommandName</span>
                                                            <span class="command-count">@cmd.Count times</span>
                                                        </span>
                                                        <span class="cmd-expand" id="icon_@cmdId">▶</span>
                                                    </div>
                                                    <div class="cmd-timestamps" id="@cmdId">
                                                        @foreach (var timestamp in cmd.Timestamps.Take(20))
                                                        {
                                                            <div class="timestamp-item">🕐 @timestamp</div>
                                                        }
                                                        @if (cmd.Timestamps.Count > 20)
                                                        {
                                                            <div class="timestamp-item" style="color: var(--text-muted); font-style: italic;">
                                                                ... and @(cmd.Timestamps.Count - 20) more
                                                            </div>
                                                        }
                                                    </div>
                                                </li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <span style="color: var(--text-muted); font-size: 0.85rem;">No command data available</span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }
    else
    {
        <div class="empty-state">
            <div class="icon">❌</div>
            <p>Invalid view type: @Model.ViewType</p>
        </div>
    }

    <script>
        function toggleCollapse(id, row) {
            var element = document.getElementById(id);
            var icon = document.getElementById('icon_' + id);
            
            if (element.classList.contains('open')) {
                element.classList.remove('open');
                icon.classList.remove('open');
            } else {
                element.classList.add('open');
                icon.classList.add('open');
            }
        }

        function toggleCmdTimestamps(id, event) {
            event.stopPropagation();
            var element = document.getElementById(id);
            var icon = document.getElementById('icon_' + id);
            
            if (element.classList.contains('open')) {
                element.classList.remove('open');
                icon.classList.remove('open');
            } else {
                element.classList.add('open');
                icon.classList.add('open');
            }
        }
    </script>
</body>
</html>