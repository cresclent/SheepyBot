@page
@model discord_bot.Pages.IndexModel

<!DOCTYPE html>
<html>
<head>
    <title>Sheepy Bot Control Panel</title>
    <link rel="stylesheet" href="/css/site.css" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
</head>
<body>
    <h1>🐑 Sheepy Bot Control Panel</h1>

    <div class="status-bar">
        <div class="status-item">
            <span class="status-dot"></span>
            <strong>Bot Status:</strong> Online
        </div>
        <div class="status-item">
            <strong>Current Banner:</strong>
            <span class="banner-display">@Model.CurrentBanner</span>
        </div>
        <div class="status-item">
            <strong>Bot Owner:</strong> <span>@Model.BotOwnerId</span>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-error")">
            @Model.Message
        </div>
    }

    <div class="card">
        <h3>🔧 Bot Owner Commands</h3>
        <p class="text-muted">These commands require bot owner permissions</p>

        <div class="row">
            <div class="col">
                <div class="card card-no-margin">
                    <h4>🔄 Reset Banner</h4>
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="action" value="ResetBanner" />
                        <p style="font-size: 14px; color: #94a3b8;">Reset the banner to a random 5-star character.</p>
                        <button type="submit" class="warning">🔄 Reset Banner</button>
                    </form>
                    <form method="post">
                        <input type="hidden" name="action" value="SetBanner" />
                        <p style="font-size: 14px; color: #94a3b8">Type character name to set the banner</p>
                        <div class="form-group" style="display: flex; flex-direction: row; gap: 8px">
                            <div style="display:flex; flex-direction:column">
                            <label for="characterSet">Character Name:</label>
                            <input type="text" id="characterSet" name="char" placeholder="Enter character name" required />
                            </div>
                            <button type="submit" class="warning">Set Banner</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="col">
                <div class="card card-no-margin">
                    <h4>📢 Global Announcement</h4>
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="action" value="GlobalAnnounce" />
                        <div class="form-group">
                            <label for="announceMessage">Message</label>
                            <textarea id="announceMessage" name="announcement" placeholder="Enter global announcement" required></textarea>
                        </div>
                        <div class="form-group">
                            <label for="pingRole">
                                <input type="checkbox" id="pingRole" name="ping" value="true" />
                                Ping configured role
                            </label>
                        </div>
                        <button type="submit" class="success">📢 Send Announcement</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="row mt-20">
            <div class="col">
                <div class="card card-no-margin">
                    <h4>🧹 Cleanup Removed Servers</h4>
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="action" value="CleanupServers" />
                        <p style="font-size: 14px; color: #94a3b8;">Check and cleanup data for servers the bot has been removed from.</p>
                        <button type="submit" class="secondary">🧹 Cleanup</button>
                    </form>
                </div>
            </div>

            <div class="col">
                <div class="card card-no-margin">
                    <h4>📊 All Vote Channels</h4>
                    <p style="font-size: 14px; color: #94a3b8;">View all configured vote channels across all servers.</p>
                    <a href="/ViewAll/Votes" class="info" style="display: inline-block; padding: 10px 28px; background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; border-radius: 10px; text-decoration: none; font-weight: 600; text-align: center; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);">📊 View All</a>
                </div>
            </div>
        </div>

        <div class="row mt-20">
            <div class="col">
                <div class="card card-no-margin">
                    <h4>📢 All Startup Channels</h4>
                    <p style="font-size: 14px; color: #94a3b8;">View all configured startup announcement channels.</p>
                    <a href="/ViewAll/Startups" class="info" style="display: inline-block; padding: 10px 28px; background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; border-radius: 10px; text-decoration: none; font-weight: 600; text-align: center; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);">📢 View All</a>
                </div>
            </div>

            <div class="col">
                <div class="card card-no-margin">
                    <h4>🌍 All Global Channels</h4>
                    <p style="font-size: 14px; color: #94a3b8;">View all configured global announcement channels.</p>
                    <a href="/ViewAll/Globals" class="info" style="display: inline-block; padding: 10px 28px; background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; border-radius: 10px; text-decoration: none; font-weight: 600; text-align: center; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);">🌍 View All</a>
                </div>
            </div>
        </div>

        <div class="row mt-20">
            <div class="col">
                <div class="card card-no-margin">
                    <h4>📊 Guild Data</h4>
                    <p style="font-size: 14px; color: #94a3b8;">View command data for specific guilds.</p>
                    <a href="/GuildData" class="info" style="display: inline-block; padding: 10px 28px; background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; border-radius: 10px; text-decoration: none; font-weight: 600; text-align: center; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);">📊 Guild Data</a>
                </div>
            </div>

            <div class="col">
                <div class="card card-no-margin">
                    <h4>💡 View Suggestions</h4>
                    <p style="font-size: 14px; color: #94a3b8;">View and manage all bot suggestions.</p>
                    <a href="/Suggestions" class="info" style="display: inline-block; padding: 10px 28px; background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; border-radius: 10px; text-decoration: none; font-weight: 600; text-align: center; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);">💡 View Suggestions</a>
                </div>
            </div>

            <div class="col">
                <div class="card card-no-margin">
                    <h4 style="display: flex; text-align: center; gap: 10px;">
                        <svg class="humbleicons hi-refresh"
                             xmlns="http://www.w3.org/2000/svg"
                             width="24" height="24" fill="none"
                             viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-linecap="round"
                                  stroke-linejoin="round" stroke-width="2"
                                  d="M20 20v-5h-5M4 4v5h5m10.938 2A8.001 8.001 0 0 0 5.07 8m-1.008 5a8.001 8.001 0 0 0 14.868 3" />
                        </svg>
                        Force Reload Files
                    </h4>
                    <p style="font-size: 14px; color: #94a3b8;">Quickly reload all the stuff in memory to actual file stuff</p>
                    <form method="post">
                        <input type="hidden" name="action" value="Reload" />
                        <button type="submit" class="success" style="display: flex; text-align: center; gap: 10px;">
                            <svg class="humbleicons hi-refresh"
                                 xmlns="http://www.w3.org/2000/svg"
                                 width="24" height="24" fill="none"
                                 viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round"
                                      stroke-linejoin="round" stroke-width="2"
                                      d="M20 20v-5h-5M4 4v5h5m10.938 2A8.001 8.001 0 0 0 5.07 8m-1.008 5a8.001 8.001 0 0 0 14.868 3" />
                            </svg>
                            Reload
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="row mt-20">
            <div class="col">
                <div class="card card-no-margin">
                    <h4>🛡️ Ignore List</h4>
                    <p style="font-size: 14px; color: #94a3b8;">Manage users who are ignored by the bot.</p>
                    <a href="/Ignore" class="info" style="display: inline-block; padding: 10px 28px; background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; border-radius: 10px; text-decoration: none; font-weight: 600; text-align: center; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);">🛡️ Manage Ignore List</a>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <h3>📋 Available Slash Commands</h3>
        <p class="text-muted">Click a command to see its description</p>
        <div class="command-grid">
            @if (Model.CommandsList != null && Model.CommandsList.Any())
            {
                @foreach (var command in Model.CommandsList)
                {
                    <div class="command-item" onclick="toggleCommand(this)">
                        <div class="command-header">
                            <span class="command-name">@command.Name</span>
                            <span class="command-toggle">▼</span>
                        </div>
                        <div class="command-description">
                            @command.Contexts
                        </div>
                    </div>
                }
            }
            else
            {
                <p style="grid-column: 1 / -1; text-align: center; color: #94a3b8; padding: 20px;">
                    No commands loaded yet. Bot may still be starting up.
                </p>
            }
        </div>
    </div>

    <div class="card">
        <h3>📋 Quick Data Overlook</h3>
        <ul>
            <li><strong>Bot Owner ID:</strong> 1157243448093573120</li>
            <li><strong>Server Count:</strong> @Model.serverCount</li>
        </ul>
    </div>

    <script>
            function toggleCommand(element) {
                document.querySelectorAll('.command-item.expanded').forEach(el => {
                    if (el !== element) el.classList.remove('expanded');
                });
                element.classList.toggle('expanded');
            }
    </script>
</body>
</html>