@page
@model discord_bot.Pages.SuggestionsModel

<!DOCTYPE html>
<html>
<head>
    <title>Sheepy Bot - Suggestions</title>
    <link rel="stylesheet" href="/css/site.css" />
    <style>
        .suggestion-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 16px;
            transition: all 0.3s ease;
        }
        .suggestion-card:hover {
            border-color: var(--primary);
        }
        .suggestion-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 10px;
        }
        .suggestion-id {
            font-weight: 700;
            color: var(--primary);
            font-size: 1.1rem;
        }
        .suggestion-status {
            padding: 4px 14px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
        }
        .status-pending {
            background: rgba(245, 158, 11, 0.2);
            color: #f59e0b;
            border: 1px solid rgba(245, 158, 11, 0.3);
        }
        .status-approved {
            background: rgba(34, 197, 94, 0.2);
            color: #22c55e;
            border: 1px solid rgba(34, 197, 94, 0.3);
        }
        .status-denied {
            background: rgba(239, 68, 68, 0.2);
            color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }
        .suggestion-user {
            color: var(--text-muted);
            font-size: 0.9rem;
        }
        .suggestion-text {
            color: var(--text);
            margin: 12px 0;
            padding: 12px;
            background: rgba(255,255,255,0.03);
            border-radius: 8px;
            border-left: 3px solid var(--primary);
        }
        .suggestion-meta {
            color: var(--text-muted);
            font-size: 0.85rem;
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }
        .suggestion-actions {
            display: flex;
            gap: 10px;
            margin-top: 12px;
            flex-wrap: wrap;
            align-items: center;
        }
        .suggestion-actions button {
            padding: 6px 16px;
            font-size: 0.85rem;
        }
        .btn-approve {
            background: linear-gradient(135deg, #22c55e, #16a34a);
        }
        .btn-approve:hover {
            background: linear-gradient(135deg, #16a34a, #15803d);
        }
        .btn-deny {
            background: linear-gradient(135deg, #ef4444, #dc2626);
        }
        .btn-deny:hover {
            background: linear-gradient(135deg, #dc2626, #b91c1c);
        }
        .btn-view {
            background: linear-gradient(135deg, #3b82f6, #2563eb);
        }
        .btn-view:hover {
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
        }
        .filter-bar {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        .filter-bar a {
            padding: 8px 20px;
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 10px;
            color: var(--text-muted);
            text-decoration: none;
            transition: all 0.3s ease;
        }
        .filter-bar a:hover {
            background: rgba(129, 140, 248, 0.1);
            border-color: var(--primary);
        }
        .filter-bar a.active {
            background: var(--primary);
            border-color: var(--primary);
            color: white;
        }
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-muted);
        }
        .empty-state .icon {
            font-size: 4rem;
            margin-bottom: 10px;
        }
        .back-link {
            display: inline-block;
            margin-bottom: 20px;
            color: var(--primary);
            text-decoration: none;
        }
        .back-link:hover {
            text-decoration: underline;
        }
        .stats-bar {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            margin-bottom: 20px;
            padding: 16px 20px;
            background: var(--card-bg);
            border-radius: 12px;
            border: 1px solid var(--border);
        }
        .stat-item {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .stat-number {
            font-weight: 700;
            font-size: 1.2rem;
            color: var(--text);
        }
        .stat-label {
            color: var(--text-muted);
            font-size: 0.9rem;
        }
        .stat-pending .stat-number { color: #f59e0b; }
        .stat-approved .stat-number { color: #22c55e; }
        .stat-denied .stat-number { color: #ef4444; }
        .stat-total .stat-number { color: var(--primary); }
        .alert {
            padding: 16px 20px;
            border-radius: 12px;
            margin-bottom: 20px;
            border: 1px solid transparent;
            font-weight: 500;
        }
        .alert-success {
            background: rgba(34, 197, 94, 0.15);
            border-color: rgba(34, 197, 94, 0.3);
            color: #4ade80;
        }
        .alert-error {
            background: rgba(239, 68, 68, 0.15);
            border-color: rgba(239, 68, 68, 0.3);
            color: #f87171;
        }
        .reason-input {
            padding: 6px 12px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--text);
            width: 200px;
        }
        .reason-input:focus {
            outline: none;
            border-color: var(--primary);
        }
    </style>
</head>
<body>
    <a href="/" class="back-link">← Back to Control Panel</a>

    <h1>💡 Bot Suggestions</h1>

    @if (TempData["Message"] != null)
    {
        <div class="alert @(TempData["Message"].ToString().StartsWith("✅") ? "alert-success" : "alert-error")">
            @TempData["Message"]
        </div>
    }

    <div class="stats-bar">
        <div class="stat-item stat-total">
            <span class="stat-number">@Model.TotalCount</span>
            <span class="stat-label">Total</span>
        </div>
        <div class="stat-item stat-pending">
            <span class="stat-number">@Model.PendingCount</span>
            <span class="stat-label">⏳ Pending</span>
        </div>
        <div class="stat-item stat-approved">
            <span class="stat-number">@Model.ApprovedCount</span>
            <span class="stat-label">✅ Approved</span>
        </div>
        <div class="stat-item stat-denied">
            <span class="stat-number">@Model.DeniedCount</span>
            <span class="stat-label">❌ Denied</span>
        </div>
    </div>

    <div class="filter-bar">
        <a href="/Suggestions" class="@(string.IsNullOrEmpty(Model.Filter) ? "active" : "")">All</a>
        <a href="/Suggestions?filter=pending" class="@(Model.Filter == "pending" ? "active" : "")">⏳ Pending</a>
        <a href="/Suggestions?filter=approved" class="@(Model.Filter == "approved" ? "active" : "")">✅ Approved</a>
        <a href="/Suggestions?filter=denied" class="@(Model.Filter == "denied" ? "active" : "")">❌ Denied</a>
    </div>

    @if (Model.Suggestions.Count == 0)
    {
        <div class="empty-state">
            <div class="icon">📭</div>
            <p>No suggestions found</p>
        </div>
    }
    else
    {
        foreach (var suggestion in Model.Suggestions)
        {
            var statusClass = suggestion.Status == "pending" ? "status-pending" :
                             suggestion.Status == "approved" ? "status-approved" : "status-denied";
            var statusEmoji = suggestion.Status == "pending" ? "⏳" :
                             suggestion.Status == "approved" ? "✅" : "❌";

            <div class="suggestion-card">
                <div class="suggestion-header">
                    <div>
                        <span class="suggestion-id">#@suggestion.Id</span>
                        <span class="suggestion-status @statusClass">@statusEmoji @suggestion.Status.ToUpper()</span>
                    </div>
                    <span class="suggestion-user">@suggestion.Username</span>
                </div>

                <div class="suggestion-text">@suggestion.Suggestion</div>

                <div class="suggestion-meta">
                    <span>📅 @suggestion.Timestamp</span>
                    <span>🏠 @suggestion.GuildName</span>
                    <span>🆔 @suggestion.UserId</span>
                </div>

                @if (suggestion.Status == "denied" && !string.IsNullOrEmpty(suggestion.Reason))
                {
                    <div style="margin-top: 8px; padding: 8px 12px; background: rgba(239, 68, 68, 0.1); border-radius: 6px; color: #f87171; font-size: 0.9rem;">
                        <strong>Reason:</strong> @suggestion.Reason
                    </div>
                }

                <div class="suggestion-actions">
                    @if (suggestion.Status == "pending")
                    {
                        <form method="post" style="display: inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="action" value="Approve" />
                            <input type="hidden" name="id" value="@suggestion.Id" />
                            <button type="submit" class="btn-approve">✅ Approve</button>
                        </form>
                        <form method="post" style="display: inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="action" value="Deny" />
                            <input type="hidden" name="id" value="@suggestion.Id" />
                            <input type="text" name="reason" placeholder="Reason (optional)" class="reason-input" />
                            <button type="submit" class="btn-deny">❌ Deny</button>
                        </form>
                    }
                    <a href="@suggestion.MessageUrl" target="_blank" class="btn-view" style="display: inline-block; padding: 6px 16px; border-radius: 8px; color: white; text-decoration: none; font-size: 0.85rem;">🔗 View in Discord</a>
                </div>
            </div>
        }
    }
</body>
</html>