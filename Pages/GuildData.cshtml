@page "{guildId?}"
@model discord_bot.Pages.GuildDataModel

<!DOCTYPE html>
<html>
<head>
    <title>Sheepy Bot - Guild Data</title>
    <link rel="stylesheet" href="/css/site.css" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
</head>
<body>
    <div class="page-title">
        <h1>📊 Guild Data</h1>
        <a href="/" class="back-link">← Back to Control Panel</a>
    </div>

    @if (Model.SelectedGuildId == 0)
    {
        <div class="search-box">
            <input type="text" id="guildSearch" placeholder="🔍 Search guilds..." onkeyup="filterGuilds()" />
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; margin-bottom: 16px;">
            <span style="color: var(--text-muted); font-size: 0.95rem;">
                Showing <span id="visibleCount">@Model.Guilds.Count</span> of @Model.Guilds.Count guilds
            </span>
            <span style="color: var(--text-muted); font-size: 0.9rem;">
                Total: @Model.Guilds.Count guilds
            </span>
        </div>

        <div class="guild-list" id="guildList">
            @foreach (var guild in Model.Guilds)
            {
                <div class="guild-card" data-guild-id="@guild.Id" data-guild-name="@guild.Name.ToLower()">
                    <div class="guild-icon">🏠</div>
                    <div class="guild-name">@guild.Name</div>
                    <div class="guild-id">ID: @guild.Id</div>
                    <a href="/GuildData/@guild.Id" class="view-link">📊 View Data</a>
                </div>
            }
        </div>

        <script>
            function filterGuilds() {
                var input = document.getElementById('guildSearch');
                var filter = input.value.toLowerCase();
                var cards = document.querySelectorAll('.guild-card');
                var visible = 0;

                cards.forEach(function(card) {
                    var name = card.getAttribute('data-guild-name');
                    var id = card.getAttribute('data-guild-id');
                    if (name.includes(filter) || id.includes(filter)) {
                        card.style.display = 'flex';
                        visible++;
                    } else {
                        card.style.display = 'none';
                    }
                });

                document.getElementById('visibleCount').textContent = visible;
            }
        </script>
    }
    else
    {
        <div class="guild-info-header">
            <div>
                <div class="guild-name-large">@Model.SelectedGuildName</div>
                <div class="guild-id-large">ID: @Model.SelectedGuildId</div>
            </div>
            <a href="/GuildData" class="back-link" style="padding: 8px 16px; font-size: 0.85rem;">← Back to All Guilds</a>
        </div>

        <div class="guild-selector">
            <form method="get" action="/GuildData">
                <label style="color: var(--text-muted); margin-right: 12px; display: inline-block; margin-bottom: 8px;">Switch to another guild:</label>
                <select name="guildId" onchange="this.form.submit()">
                    <option value="0">-- Back to guild list --</option>
                    @foreach (var guild in Model.Guilds)
                    {
                        <option value="@guild.Id" selected="@(Model.SelectedGuildId == guild.Id)">
                            @guild.Name (@guild.Id)
                        </option>
                    }
                </select>
            </form>
        </div>

        @if (Model.GuildData != null)
        {
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-label">Total Users</div>
                    <div class="stat-value">@Model.GuildData.TotalUsers</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Total Commands</div>
                    <div class="stat-value">@Model.GuildData.TotalCommands</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Channels Used</div>
                    <div class="stat-value">@Model.GuildData.ChannelCount</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Go To Server</div>
                    <form method="post" style="margin-top: 8px;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="action" value="ToServer" />
                        <input type="hidden" name="dataOne" value="@Model.SelectedGuildId" />
                        <button type="submit" style="
                            width: 100%;
                            padding: 8px 16px;
                            background: var(--primary);
                            color: white;
                            border: none;
                            border-radius: 8px;
                            font-weight: 600;
                            cursor: pointer;
                            font-size: 1rem;
                            transition: all 0.3s ease;"accesskey=""
                            onmouseover="this.style.background='var(--primary-dark)'"
                            onmouseout="this.style.background='var(--primary)'">
                            Go!
                        </button>
                    </form>
                </div>
            </div>

            @if (Model.GuildData.TopUsers.Count > 0)
            {
                <h3 class="section-title">Top Users</h3>
                <table>
                    <thead>
                        <tr>
                            <th style="width: 60px;">Rank</th>
                            <th>User</th>
                            <th style="width: 120px;">Commands</th>
                            <th style="width: 40px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.GuildData.TopUsers.Count; i++)
                        {
                            var user = Model.GuildData.TopUsers[i];
                            var medal = i == 0 ? "🥇" : i == 1 ? "🥈" : i == 2 ? "🥉" : $"#{i + 1}";
                            var collapseId = $"userCollapse_{i}";
                            <tr class="user-row" onclick="toggleCollapse('@collapseId', this)">
                                <td>@medal</td>
                                <td>
                                    <div class="user-name-cell">
                                        <div class="user-avatar">@(user.UserName?.FirstOrDefault().ToString().ToUpper() ?? "?")</div>
                                        <strong>@user.UserName</strong>
                                        <span class="badge-count">@user.TotalCommands</span>
                                    </div>
                                </td>
                                <td>@user.TotalCommands</td>
                                <td>
                                    <span class="expand-icon" id="icon_@collapseId">▼</span>
                                </td>
                            </tr>
                            <tr class="command-details" id="@collapseId">
                                <td colspan="4">
                                    <div style="padding: 8px 0;">
                                        <strong style="color: var(--text-muted); font-size: 0.8rem;">Command Usage:</strong>
                                        @if (user.CommandCounts.Count > 0)
                                        {
                                            <ul class="cmd-list">
                                                @foreach (var cmd in user.CommandCounts)
                                                {
                                                    var cmdId = $"cmd_{collapseId}_{cmd.CommandName.Replace("/", "")}";
                                                    <li>
                                                        <div class="cmd-header" onclick="toggleCmdTimestamps('@cmdId', event)">
                                                            <span class="command-spans">
                                                                <span class="command-name">/@cmd.CommandName</span>
                                                                <span class="command-count">@cmd.Count times</span>
                                                            </span>
                                                            <span class="cmd-expand" id="icon_@cmdId">▶</span>
                                                        </div>
                                                        <div class="cmd-timestamps" id="@cmdId">
                                                            @foreach (var timestamp in cmd.Timestamps.Take(20))
                                                            {
                                                                <div class="timestamp-item">🕐 @timestamp</div>
                                                            }
                                                            @if (cmd.Timestamps.Count > 20)
                                                            {
                                                                <div class="timestamp-item" style="color: var(--text-muted); font-style: italic;">
                                                                    ... and @(cmd.Timestamps.Count - 20) more
                                                                </div>
                                                            }
                                                        </div>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                        else
                                        {
                                            <span style="color: var(--text-muted); font-size: 0.85rem;">No command data available</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            @if (Model.GuildData.ChannelStats.Count > 0)
            {
                <h3 class="section-title">Channel Breakdown</h3>
                <table>
                    <thead>
                        <tr>
                            <th>Channel</th>
                            <th>Commands</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var channel in Model.GuildData.ChannelStats.OrderByDescending(c => c.CommandCount))
                        {
                            <tr>
                                <td>@channel.ChannelName</td>
                                <td>@channel.CommandCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
        else
        {
            <div class="empty-state">
                <div class="icon">📭</div>
                <p>No data found for this guild</p>
            </div>
        }
    }

    <script>
        function toggleCollapse(id, row) {
            var element = document.getElementById(id);
            var icon = document.getElementById('icon_' + id);
            
            if (element.classList.contains('open')) {
                element.classList.remove('open');
                icon.classList.remove('open');
            } else {
                element.classList.add('open');
                icon.classList.add('open');
            }
        }

        function toggleCmdTimestamps(id, event) {
            event.stopPropagation();
            var element = document.getElementById(id);
            var icon = document.getElementById('icon_' + id);
            
            if (element.classList.contains('open')) {
                element.classList.remove('open');
                icon.classList.remove('open');
            } else {
                element.classList.add('open');
                icon.classList.add('open');
            }
        }
    </script>
</body>
</html>