@page
@model discord_bot.Pages.IgnoreModel

<!DOCTYPE html>
<html>
<head>
    <title>Sheepy Bot - Ignore List</title>
    <link rel="stylesheet" href="/css/site.css" />
</head>
<body>
    <a href="/" class="back-link">← Back to Control Panel</a>

    <div class="page-title">
        <h1>🛡️ Ignore List</h1>
        <span style="color: var(--text-muted); font-size: 0.9rem;">Users on this list will not have their commands logged</span>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert @(TempData["Message"].ToString().StartsWith("✅") ? "alert-success" : "alert-error")">
            @TempData["Message"]
        </div>
    }

    <div class="stats-bar">
        <div>
            <span class="stat-number">@Model.IgnoredUsers.Count</span>
            <span class="stat-label">Ignored Users</span>
        </div>
    </div>

    <div class="add-form">
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="action" value="Add" />
            <input type="text" name="userId" placeholder="Enter User ID to ignore" required />
            <button type="submit" class="btn-add">➕ Add User</button>
        </form>
    </div>

    @if (Model.IgnoredUsers.Count == 0)
    {
        <div class="empty-state">
            <div class="icon">📭</div>
            <p>No users on the ignore list</p>
        </div>
    }
    else
    {
        foreach (var user in Model.IgnoredUsers)
        {
            <div class="ignore-card">
                <div class="ignore-user">
                    <div class="avatar">@(user.Username?.FirstOrDefault().ToString().ToUpper() ?? "?")</div>
                    <div>
                        <div class="username">@user.Username</div>
                        <div class="user-id">ID: @user.UserId</div>
                    </div>
                </div>
                <div>
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="action" value="Remove" />
                        <input type="hidden" name="userId" value="@user.UserId" />
                        <button type="submit" class="btn-unignore">🗑️ Unignore</button>
                    </form>
                </div>
            </div>
        }
    }
</body>
</html>