@page
@model discord_bot.Pages.IgnoreModel

<!DOCTYPE html>
<html>
<head>
    <title>Sheepy Bot - Ignore List</title>
    <link rel="stylesheet" href="/css/site.css" />
    <style>
        .ignore-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 10px;
        }
        .ignore-user {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .ignore-user .avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: white;
            font-size: 1.2rem;
        }
        .ignore-user .username {
            font-weight: 600;
            color: var(--text);
        }
        .ignore-user .user-id {
            color: var(--text-muted);
            font-size: 0.85rem;
        }
        .btn-unignore {
            background: linear-gradient(135deg, #ef4444, #dc2626);
            padding: 8px 20px;
            border-radius: 8px;
            color: white;
            border: none;
            cursor: pointer;
            font-weight: 600;
        }
        .btn-unignore:hover {
            background: linear-gradient(135deg, #dc2626, #b91c1c);
        }
        .btn-add {
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            padding: 10px 24px;
            border-radius: 10px;
            color: white;
            border: none;
            cursor: pointer;
            font-weight: 600;
        }
        .btn-add:hover {
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
        }
        .add-form {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 24px;
            padding: 20px;
            background: var(--card-bg);
            border-radius: 12px;
            border: 1px solid var(--border);
        }
        .add-form input {
            flex: 1;
            min-width: 200px;
            padding: 10px 16px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            font-size: 0.95rem;
        }
        .add-form input:focus {
            outline: none;
            border-color: var(--primary);
        }
        .add-form input::placeholder {
            color: var(--text-muted);
        }
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-muted);
        }
        .empty-state .icon {
            font-size: 4rem;
            margin-bottom: 10px;
        }
        .back-link {
            display: inline-block;
            margin-bottom: 20px;
            color: var(--primary);
            text-decoration: none;
        }
        .back-link:hover {
            text-decoration: underline;
        }
        .stats-bar {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            margin-bottom: 20px;
            padding: 16px 20px;
            background: var(--card-bg);
            border-radius: 12px;
            border: 1px solid var(--border);
        }
        .stat-number {
            font-weight: 700;
            font-size: 1.2rem;
            color: var(--text);
        }
        .stat-label {
            color: var(--text-muted);
            font-size: 0.9rem;
        }
        .alert {
            padding: 16px 20px;
            border-radius: 12px;
            margin-bottom: 20px;
            border: 1px solid transparent;
            font-weight: 500;
        }
        .alert-success {
            background: rgba(34, 197, 94, 0.15);
            border-color: rgba(34, 197, 94, 0.3);
            color: #4ade80;
        }
        .alert-error {
            background: rgba(239, 68, 68, 0.15);
            border-color: rgba(239, 68, 68, 0.3);
            color: #f87171;
        }
        .page-title {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }
    </style>
</head>
<body>
    <a href="/" class="back-link">← Back to Control Panel</a>

    <div class="page-title">
        <h1>🛡️ Ignore List</h1>
        <span style="color: var(--text-muted); font-size: 0.9rem;">Users on this list will not have their commands logged</span>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert @(TempData["Message"].ToString().StartsWith("✅") ? "alert-success" : "alert-error")">
            @TempData["Message"]
        </div>
    }

    <div class="stats-bar">
        <div>
            <span class="stat-number">@Model.IgnoredUsers.Count</span>
            <span class="stat-label">Ignored Users</span>
        </div>
    </div>

    <div class="add-form">
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="action" value="Add" />
            <input type="text" name="userId" placeholder="Enter User ID to ignore" required />
            <button type="submit" class="btn-add">➕ Add User</button>
        </form>
    </div>

    @if (Model.IgnoredUsers.Count == 0)
    {
        <div class="empty-state">
            <div class="icon">📭</div>
            <p>No users on the ignore list</p>
        </div>
    }
    else
    {
        foreach (var user in Model.IgnoredUsers)
        {
            <div class="ignore-card">
                <div class="ignore-user">
                    <div class="avatar">@(user.Username?.FirstOrDefault().ToString().ToUpper() ?? "?")</div>
                    <div>
                        <div class="username">@user.Username</div>
                        <div class="user-id">ID: @user.UserId</div>
                    </div>
                </div>
                <div>
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="action" value="Remove" />
                        <input type="hidden" name="userId" value="@user.UserId" />
                        <button type="submit" class="btn-unignore">🗑️ Unignore</button>
                    </form>
                </div>
            </div>
        }
    }
</body>
</html>